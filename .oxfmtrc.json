{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "singleQuote": true,
    "tabWidth": 4,
    "sortPackageJson": false,
    "ignorePatterns": [
        "**/node_modules/**",
        "**/coverage/**",
        "**/.nyc_output/**",
        "pnpm-lock.yaml",
        "**/*.json",
        "**/*.jsonc",
        "**/*.yml",
        "**/*.yaml",
        "**/*.md"
    ]
}
